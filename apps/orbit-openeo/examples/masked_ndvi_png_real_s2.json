{
  "process": {
    "process_graph": {
      "load1": {
        "process_id": "load_collection",
        "arguments": {
          "id": "sentinel-2-l2a",
          "spatial_extent": {
            "west": 16.30,
            "south": 48.18,
            "east": 16.40,
            "north": 48.24
          },
          "temporal_extent": ["2024-06-01", "2024-06-30"],
          "bands": ["B04", "B08", "SCL"]
        }
      },
      "m1": {
        "process_id": "mask_scl_dilation",
        "arguments": {
          "data": { "from_node": "load1" }
        }
      },
      "ndvi1": {
        "process_id": "ndvi",
        "arguments": {
          "data": { "from_node": "m1" },
          "nir": "B08",
          "red": "B04",
          "target_band": "ndvi"
        }
      },
      "reduce1": {
        "process_id": "reduce_dimension",
        "arguments": {
          "data": { "from_node": "ndvi1" },
          "dimension": "t",
          "reducer": {
            "process_graph": {
              "mean1": {
                "process_id": "mean",
                "arguments": { "data": { "from_parameter": "data" } },
                "result": true
              }
            }
          }
        }
      },
      "save1": {
        "process_id": "save_result",
        "arguments": {
          "data":   { "from_node": "reduce1" },
          "format": "PNG"
        },
        "result": true
      }
    }
  },
  "title": "Masked NDVI mean — Wien June 2024 — PNG",
  "description": "Real Sentinel-2 L2A (B04/B08/SCL) via Element84 STAC, mask_scl_dilation, NDVI, temporal mean, PNG output."
}
