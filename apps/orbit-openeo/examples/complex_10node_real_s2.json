{
  "process": {
    "process_graph": {
      "load1": {
        "process_id": "load_collection",
        "arguments": {
          "id": "sentinel-2-l2a",
          "spatial_extent": {"west": 16.30, "south": 48.18, "east": 16.40, "north": 48.24},
          "temporal_extent": ["2024-06-01", "2024-06-30"],
          "bands": ["B04", "B08", "SCL"]
        }
      },
      "mask1": {
        "process_id": "mask_scl_dilation",
        "arguments": {"data": {"from_node": "load1"}}
      },
      "ndvi1": {
        "process_id": "ndvi",
        "arguments": {"data": {"from_node": "mask1"}, "nir": "B08", "red": "B04", "target_band": "ndvi"}
      },
      "apply1": {
        "process_id": "apply",
        "arguments": {
          "data": {"from_node": "ndvi1"},
          "process": {"process_graph": {
            "p": {"process_id": "add", "arguments": {"x": {"from_parameter": "x"}, "y": 1.0}, "result": true}
          }}
        }
      },
      "apply2": {
        "process_id": "apply",
        "arguments": {
          "data": {"from_node": "apply1"},
          "process": {"process_graph": {
            "p": {"process_id": "multiply", "arguments": {"x": {"from_parameter": "x"}, "y": 100.0}, "result": true}
          }}
        }
      },
      "apply3": {
        "process_id": "apply",
        "arguments": {
          "data": {"from_node": "apply2"},
          "process": {"process_graph": {
            "p": {"process_id": "subtract", "arguments": {"x": {"from_parameter": "x"}, "y": 50.0}, "result": true}
          }}
        }
      },
      "apply4": {
        "process_id": "apply",
        "arguments": {
          "data": {"from_node": "apply3"},
          "process": {"process_graph": {
            "p": {"process_id": "divide", "arguments": {"x": {"from_parameter": "x"}, "y": 2.0}, "result": true}
          }}
        }
      },
      "apply5": {
        "process_id": "apply",
        "arguments": {
          "data": {"from_node": "apply4"},
          "process": {"process_graph": {
            "p": {"process_id": "multiply", "arguments": {"x": {"from_parameter": "x"}, "y": 1.5}, "result": true}
          }}
        }
      },
      "reduce1": {
        "process_id": "reduce_dimension",
        "arguments": {
          "data": {"from_node": "apply5"},
          "dimension": "t",
          "reducer": {"process_graph": {
            "mean1": {"process_id": "mean", "arguments": {"data": {"from_parameter": "data"}}, "result": true}
          }}
        }
      },
      "save1": {
        "process_id": "save_result",
        "arguments": {"data": {"from_node": "reduce1"}, "format": "PNG"},
        "result": true
      }
    }
  },
  "title": "10-node S2: load → mask_scl_dilation → ndvi → 5×apply → reduce(mean) → PNG"
}
